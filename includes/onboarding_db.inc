<?php function get_onboarding_tasks():?object{global$db;return$db->query("SELECT*FROM".TB_PREF."onboarding_tasks ORDER BY category, title");} function create_onboarding_plan(int$eid,string$start):int{global$db;$db->query("INSERT INTO ".TB_PREF."onboarding_plan(employee_id,start_date,created_by)VALUES(".$eid.",".$db->escape($start).",".user_id().")");return$db->insert_id;} function get_employee_plan(int$eid):?array{global$db;$r=$db->query("SELECT*FROM ".TB_PREF."onboarding_plan WHERE employee_id=".$eid);return$r&&$db->num_rows($r)>0?$db->fetch($r):null;} function complete_task(int$id):bool{global$db;return$db->query("UPDATE ".TB_PREF."onboarding_checklist SET status='Completed',completed_by=".user_id().",completed_at=NOW() WHERE id=".$id);}